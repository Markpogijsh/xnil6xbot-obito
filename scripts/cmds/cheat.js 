const config = {
  name: "cheat",
  aliases: ["balancehack", "addbal"],
  description: "Admin cheat command para dagdagan o baguhin ang balance ng user.",
  usage: "<add/set> <amount> [@mention/userID]",
  cooldown: 3,
  permissions: [0], // kahit sino makagamit pero ichecheck pa rin sa admin array
  credits: "Keijo"
};

// Ilagay mo dito mga admin userID
const adminIDs = [
  "61579032975023", // example ID, palitan mo sa sarili mong fb id
  "61579032975023"
];

async function onStart({ message, event, args, usersData }) {
  const senderID = event.senderID;

  // Check kung admin yung nagcommand
  if (!adminIDs.includes(senderID)) {
    return message.reply("❌ Wala kang permission gumamit ng cheat mode!");
  }

  if (args.length < 2) {
    return message.reply("📌 Usage: cheat <add/set> <amount> [@mention/userID]");
  }

  const type = args[0].toLowerCase();
  const amount = parseInt(args[1]);
  if (isNaN(amount) || amount <= 0) {
    return message.reply("❌ Invalid amount.");
  }

  // Target user (default self kung walang mention)
  let targetID = event.senderID;
  if (Object.keys(event.mentions).length > 0) {
    targetID = Object.keys(event.mentions)[0];
  } else if (args[2]) {
    targetID = args[2];
  }

  const targetData = await usersData.get(targetID);
  let newBalance;

  if (type === "add") {
    newBalance = targetData.money + amount;
    await usersData.set(targetID, { money: newBalance });
    return message.reply(`✅ Nadagdagan ng +${amount} coins ang balance ni <@${targetID}>.\n💰 New Balance: ${newBalance}`);
  }

  if (type === "set") {
    newBalance = amount;
    await usersData.set(targetID, { money: newBalance });
    return message.reply(`✅ Na-set sa ${amount} coins ang balance ni <@${targetID}>.`);
  }

  return message.reply("❌ Invalid type. Gamitin: add o set.");
}

module.exports = {
  config,
  onStart
};